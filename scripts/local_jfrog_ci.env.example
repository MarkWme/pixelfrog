# Copy to local_jfrog_ci.env (gitignored) and fill in. Source is automatic when you run local_jfrog_ci.sh

# Required: platform URL, no trailing slash (same as GitHub variable JF_URL)
JF_URL=https://your-subdomain.jfrog.io

# Required: Artifactory identity for jf + Conan (access token or reference token)
JF_ACCESS_TOKEN=

# Required for Conan remote login (email or username shown in Artifactory)
JF_CONAN_USER=

# Optional: match GitHub Actions repository variables (defaults shown)
# JFROG_BUILD_NAME=pixelfrog
# CONAN_VIRTUAL_REPO_KEY=mwpf-conan-virtual-dev
# CONAN_LOCAL_REPO_KEY=mwpf-conan-local-dev
# GENERIC_REPO_KEY=mwpf-generic-local
# JF_PROJECT_KEY=

# Build number for Build Info (default: local-<timestamp>)
# BUILD_NUMBER=local-20260325120000

# Set to 1 to mirror CI JF_CONAN_PUBLISH_DEPS (jf conan upload to local repo)
# LOCAL_PUBLISH_DEPS=0

# Set to 1 to use conan-io/conan-extensions "art" commands (conan art:build-info create/upload).
# Requires packages in your Conan LOCAL repo — the script will run jf conan upload when this is on.
# See https://docs.conan.io/2/security/sboms.html
# CONAN_ART_BUILDINFO=0

# For conan art:build-info path: --force uploads so package binaries exist under LOCAL (avoids missing conan_package.tgz)
# CONAN_UPLOAD_FORCE=1

# If art:build-info upload still 400s on paths, try CONAN_ART_ADD_CACHED_DEPS=0 (narrower graph, fewer package files)
# CONAN_ART_ADD_CACHED_DEPS=1

# Optional URL stored in published Build Info (default: local://hostname/build)
# BUILD_URL=
